{
  "name": "uxinspect-dashboard-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "uxinspect team dashboard (app.uxinspect.com) — Cloudflare Pages",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler pages deploy dist --project-name=uxinspect-dashboard"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wrangler": "^4.0.0"
  }
}
